# Rails Configuration
RAILS_ENV=production
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here

# Database Configuration
DATABASE_USERNAME=cardy
DATABASE_PASSWORD=your_secure_database_password_here
DATABASE_HOST=localhost
DATABASE_PORT=5432
DB_POOL=15  # Connection pool size (should be >= RAILS_MAX_THREADS + Solid Queue workers)

# Server Configuration
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
PORT=3000

# Application URL
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# GitHub OAuth Configuration
# Create an OAuth App at https://github.com/settings/developers
# Set callback URL to: https://your-domain.com/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OpenClaw webhook (optional)
# When a task lands on a webhook-enabled column, ClawDeck POSTs to the OpenClaw
# /hooks/agent endpoint to trigger the agent set on the ClawDeck agent.
# OPENCLAW_HOOKS_URL: full URL of the gateway hooks/agent endpoint.
# OPENCLAW_HOOKS_TOKEN: the dedicated hooks shared secret (hooks.token in OpenClaw).
OPENCLAW_HOOKS_URL=https://your-openclaw-host/hooks/agent
OPENCLAW_HOOKS_TOKEN=your_openclaw_hooks_token_here
