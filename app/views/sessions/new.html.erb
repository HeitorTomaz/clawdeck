<% content_for :title, "Sign in" %>
<div class="max-w-md mx-auto pt-12">
  <div class="text-left mb-8">
    <h1 class="text-5xl font-semibold text-content leading-[1.05] tracking-[-0.04em] mb-4">
      Welcome<br>back.
    </h1>
    <p class="text-base text-content-secondary leading-relaxed">
      Pick up where you left off — your boards and your agents are waiting.
    </p>
  </div>

  <% if User.github_oauth_enabled? %>
    <%= button_to "/auth/github", method: :post, class: "w-full cursor-pointer inline-flex items-center justify-center gap-2 px-4 py-3 bg-bg-base text-content hover:bg-bg-hover transition-colors text-sm font-medium mb-5 border border-[rgba(28,28,28,0.4)] rounded-md", data: { turbo: false } do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
      </svg>
      Continue with GitHub
    <% end %>

    <div class="flex items-center gap-3 mb-5">
      <div class="flex-1 h-px bg-border"></div>
      <span class="text-xs text-content-muted">or</span>
      <div class="flex-1 h-px bg-border"></div>
    </div>
  <% end %>

  <%= form_with url: session_url, class: "space-y-4 mb-6", html: { autocomplete: "off" } do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "block text-sm font-medium text-content mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "name@domain.com", value: params[:email_address], class: "block w-full px-4 h-11 bg-bg-base border border-border rounded-md focus-soft text-content text-sm placeholder:text-content-muted" %>
    </div>
    <div>
      <%= form.label :password, "Password", class: "block text-sm font-medium text-content mb-2" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter password", class: "block w-full px-4 h-11 bg-bg-base border border-border rounded-md focus-soft text-content text-sm placeholder:text-content-muted" %>
    </div>

    <div class="pt-2">
      <%= form.submit "Sign in", class: "w-full cursor-pointer h-11 px-6 bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity text-sm font-medium rounded-md" %>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to "Forgot password?", new_password_path, class: "text-sm text-content-muted hover:text-content underline transition-colors" %>
      <%= link_to "Create account →", new_registration_path, class: "text-sm font-medium text-content hover:opacity-80 transition-opacity" %>
    </div>
  <% end %>
</div>
