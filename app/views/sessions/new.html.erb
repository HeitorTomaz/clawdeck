<% content_for :title, "Sign in" %>
<div class="max-w-md mx-auto pt-6">
  <%# Tricolor stripe — brand signature %>
  <div class="tricolor-stripe mb-10"></div>

  <div class="text-left mb-8">
    <div class="label-uppercase text-[#7e7e7e] mb-4">Sign in</div>
    <h1 class="font-display text-5xl font-extrabold uppercase text-white leading-[0.95] tracking-tight mb-5">
      Welcome<br>back.
    </h1>
    <p class="text-sm font-light text-[#bbbbbb] leading-relaxed">
      Pick up where you left off — your boards and your agents are waiting.
    </p>
  </div>

  <% if User.github_oauth_enabled? %>
    <%= button_to "/auth/github", method: :post, class: "w-full cursor-pointer inline-flex items-center justify-center gap-2 p-3 bg-[#1a1a1a] text-white hover:bg-[#262626] transition-colors text-xs font-bold tracking-[0.12em] uppercase mb-5 border border-[#3c3c3c]", data: { turbo: false }, form: { style: "border-radius:0" } do %>
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
      </svg>
      Continue with GitHub
    <% end %>

    <div class="flex items-center gap-3 mb-5">
      <div class="flex-1 h-px bg-[#262626]"></div>
      <span class="text-[10px] font-bold tracking-[0.2em] uppercase text-[#555]">or</span>
      <div class="flex-1 h-px bg-[#262626]"></div>
    </div>
  <% end %>

  <%= form_with url: session_url, class: "space-y-4 mb-6", html: { autocomplete: "off" } do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "block label-uppercase text-[#7e7e7e] mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "name@domain.com", value: params[:email_address], class: "block w-full px-4 h-12 bg-[#1a1a1a] border border-[#3c3c3c] text-white text-sm font-light placeholder:text-[#555] focus:outline-none focus:border-white transition-colors", style: "border-radius:0" %>
    </div>
    <div>
      <%= form.label :password, "Password", class: "block label-uppercase text-[#7e7e7e] mb-2" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter password", class: "block w-full px-4 h-12 bg-[#1a1a1a] border border-[#3c3c3c] text-white text-sm font-light placeholder:text-[#555] focus:outline-none focus:border-white transition-colors", style: "border-radius:0" %>
    </div>

    <div class="pt-2">
      <%= form.submit "Sign in →", class: "w-full cursor-pointer h-12 px-8 bg-white text-black hover:bg-[#bbbbbb] transition-colors text-xs font-bold tracking-[0.18em] uppercase", style: "border-radius:0" %>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to "Forgot password?", new_password_path, class: "label-uppercase text-[#7e7e7e] hover:text-white transition-colors" %>
      <%= link_to "Create account →", new_registration_path, class: "label-uppercase text-white hover:text-[#bbbbbb] transition-colors" %>
    </div>
  <% end %>
</div>
