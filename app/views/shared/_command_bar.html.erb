<div data-controller="command-bar" data-command-bar-open-value="false" data-command-bar-mode-value="search">
  <%# Backdrop %>
  <div data-command-bar-target="backdrop" data-action="click->command-bar#close"
       class="hidden fixed inset-0 bg-black/30 z-[300]"></div>

  <%# Centering wrapper %>
  <div data-command-bar-target="dialog"
       class="hidden fixed inset-0 z-[301] flex items-start justify-center pt-[15vh] pointer-events-none">
    <%# Command bar container %>
    <div class="w-[520px] max-w-[calc(100vw-2rem)] max-h-[65vh] flex flex-col pointer-events-auto overflow-hidden animate-drop-in bg-bg-elevated border border-border rounded-2xl"
         style="box-shadow:0 24px 60px rgba(0,0,0,0.12)">

      <%# Input bar %>
      <div class="flex items-center gap-2.5 px-4 py-3 border-b border-border">
        <%# Mode icon %>
        <div data-command-bar-target="modeIcon" class="flex-shrink-0 flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="opacity:0.6">
            <circle cx="7" cy="7" r="5" stroke="#5f5f5d" stroke-width="1.5"/>
            <path d="M11 11L14 14" stroke="#5f5f5d" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <%# Input %>
        <input type="text"
               data-command-bar-target="input"
               data-action="input->command-bar#onInput keydown->command-bar#onInputKeydown"
               placeholder="Search cards or run a command..."
               class="flex-1 bg-transparent border-none text-sm font-normal text-content placeholder:text-content-muted focus:outline-none focus:ring-0" />
        <%# Back button (agent mode only) %>
        <button type="button"
                data-command-bar-target="backButton"
                data-action="click->command-bar#switchToSearch"
                class="hidden cursor-pointer text-xs font-medium text-content-muted bg-bg-base border border-border px-2 py-1 rounded-md">Back</button>
        <%# Esc badge %>
        <span class="text-xs font-medium text-content-muted bg-bg-base border border-border px-2 py-1 rounded-md">esc</span>
      </div>

      <%# Body (scrollable) %>
      <div data-command-bar-target="body" class="flex-1 overflow-y-auto py-2">

        <%# Search results (hidden by default) %>
        <div data-command-bar-target="searchResults" class="hidden"></div>

        <%# Quick actions (shown by default in search mode) %>
        <div data-command-bar-target="actionsPanel" class="px-2">
          <div class="text-xs font-medium text-content-muted px-3 py-2">Actions</div>

          <% [
            ["agent", "⌨️", "Ask about tasks", "Query your boards"],
            ["today", "☀️", "What should I focus on?", "Top priorities"],
            ["recap", "📊", "Weekly recap", "Summary of progress"],
          ].each do |action_id, icon, label, hint| %>
            <button type="button"
                    data-action="click->command-bar#executeAction"
                    data-action-id="<%= action_id %>"
                    class="flex items-center gap-2.5 w-full rounded-md cursor-pointer border-none bg-transparent hover:bg-bg-hover transition-colors px-2.5 py-2 text-left">
              <div class="flex items-center justify-center flex-shrink-0 w-7 h-7 rounded-md bg-bg-base border border-border text-sm">
                <%= icon %>
              </div>
              <div class="flex-1">
                <div class="text-sm font-medium text-content"><%= label %></div>
              </div>
              <span class="text-xs text-content-muted"><%= hint %></span>
            </button>
          <% end %>
        </div>

        <%# Agent panel (hidden by default) %>
        <div data-command-bar-target="agentPanel" class="hidden">
          <div data-command-bar-target="agentMessages" class="flex flex-col gap-2 px-4 py-2">
            <%# Empty state rendered by JS %>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
