<%# New Board Modal — shared between board and home pages %>
<div id="new-board-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/30" onclick="document.getElementById('new-board-modal').classList.add('hidden')"></div>
  <div class="relative bg-bg-elevated border border-border rounded-2xl w-full max-w-sm mx-4 overflow-hidden" style="box-shadow: 0 12px 40px rgba(0,0,0,0.12);">
    <div class="px-5 py-4 border-b border-border flex items-center justify-between">
      <span class="text-base font-semibold text-content">New Board</span>
      <button type="button"
              onclick="document.getElementById('new-board-modal').classList.add('hidden')"
              class="p-2 rounded-md text-content-muted hover:text-content hover:bg-bg-hover transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%= form_with model: Board.new, url: boards_path, class: "p-5 space-y-4" do |form| %>
      <div>
        <label class="block text-sm font-medium text-content mb-2">Board Name</label>
        <%= form.text_field :name,
            required: true,
            placeholder: "e.g., Work, Personal, Side Project",
            class: "w-full px-3 py-2 text-sm bg-bg-base border border-border rounded-md focus-soft text-content placeholder:text-content-muted" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-content mb-2">Icon</label>
        <div class="flex flex-wrap gap-2" id="icon-group">
          <% available_icons = Board::DEFAULT_ICONS.dup %>
          <% if current_user.agent_last_active_at.present? && current_user.agent_emoji.present? && !available_icons.include?(current_user.agent_emoji) %>
            <% available_icons << current_user.agent_emoji %>
          <% end %>
          <% available_icons.each do |icon| %>
            <button type="button"
                    onclick="selectBoardIcon(this, '<%= icon %>')"
                    data-icon="<%= icon %>"
                    class="w-10 h-10 flex items-center justify-center rounded-md bg-bg-base border border-border hover:bg-bg-hover transition-colors text-xl cursor-pointer <%= icon == '📋' ? 'ring-2 ring-content ring-offset-2 ring-offset-bg-elevated' : '' %>">
              <%= icon %>
            </button>
          <% end %>
        </div>
        <%= form.hidden_field :icon, value: "📋", id: "board-icon-field" %>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <button type="button"
                onclick="document.getElementById('new-board-modal').classList.add('hidden')"
                class="px-4 py-2 text-sm font-medium rounded-md border border-[rgba(28,28,28,0.4)] text-content hover:bg-bg-hover transition-colors cursor-pointer">
          Cancel
        </button>
        <%= form.submit "Create Board", class: "px-4 py-2 text-sm font-medium rounded-md bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  function selectBoardIcon(btn, icon) {
    document.getElementById('board-icon-field').value = icon;
    document.querySelectorAll('#icon-group button').forEach(b => {
      b.classList.remove('ring-2', 'ring-content', 'ring-offset-2', 'ring-offset-bg-elevated');
    });
    btn.classList.add('ring-2', 'ring-content', 'ring-offset-2', 'ring-offset-bg-elevated');
  }
</script>
