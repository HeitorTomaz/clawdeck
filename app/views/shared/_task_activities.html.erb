<%
  activities = task.activities.reload.recent.limit(10)
%>
<div id="task-activities-<%= task.id %>">
  <% if activities.any? %>
    <div class="flex flex-col gap-0 relative">
      <%# Vertical connector line %>
      <div class="absolute left-[13px] top-3.5 bottom-3.5 w-px bg-border"></div>

      <% activities.each do |activity| %>
        <%
          # Determine icon style by activity type (warm palette)
          if activity.actor_type == "agent"
            icon = { bg: "rgba(160,116,0,0.10)", border: "rgba(160,116,0,0.25)", color: "#a07400", symbol: "🤖" }
          elsif activity.action == "created"
            icon = { bg: "rgba(31,95,168,0.10)", border: "rgba(31,95,168,0.25)", color: "#1f5fa8", symbol: "+" }
          elsif activity.action == "moved"
            icon = { bg: "rgba(109,78,184,0.10)", border: "rgba(109,78,184,0.25)", color: "#6d4eb8", symbol: "→" }
          elsif activity.action == "updated" && activity.field_name == "priority"
            icon = { bg: "rgba(30,122,78,0.10)", border: "rgba(30,122,78,0.25)", color: "#1e7a4e", symbol: "!" }
          elsif activity.action == "updated"
            icon = { bg: "rgba(160,116,0,0.10)", border: "rgba(160,116,0,0.25)", color: "#a07400", symbol: "✎" }
          else
            icon = { bg: "#fcfbf8", border: "#eceae4", color: "#5f5f5d", symbol: "•" }
          end
        %>
        <div class="flex items-start gap-2.5 py-2 relative">
          <div class="w-[26px] h-[26px] min-w-[26px] rounded-full flex items-center justify-center text-xs font-semibold z-10"
               style="background:<%= icon[:bg] %>;border:1px solid <%= icon[:border] %>;color:<%= icon[:color] %>">
            <%= icon[:symbol] %>
          </div>
          <div class="flex-1 pt-0.5">
            <div class="text-xs font-normal text-content-secondary leading-relaxed">
              <%= activity.description %>
            </div>
            <div class="text-xs text-content-muted mt-0.5">
              <%= time_ago_in_words(activity.created_at) %> ago
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-xs italic text-content-muted">No activity yet</div>
  <% end %>
</div>
