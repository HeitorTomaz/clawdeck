<% content_for :title, "Edit agent" %>

<div class="space-y-6 mt-12 max-w-md mx-auto px-4">
  <div>
    <h2 class="text-lg font-semibold text-content font-display">Edit agent</h2>
  </div>

  <div class="bg-bg-surface border border-border rounded-lg p-5">
    <%= render "agents/form", agent: @agent, submit_label: "Save changes", url: agent_path(@agent), method: :patch %>
  </div>
</div>
