<% content_for :title, "New agent" %>

<div class="space-y-6 mt-12 max-w-md mx-auto px-4">
  <div>
    <h2 class="text-2xl font-semibold tracking-[-0.025em] text-content">New agent</h2>
    <p class="text-sm text-content-muted mt-1">Agents are how external automations connect to ClawDeck. Each has its own API tokens.</p>
  </div>

  <div class="bg-bg-elevated border border-border rounded-xl p-6">
    <%= render "agents/form", agent: @agent, submit_label: "Create agent", url: agents_path, method: :post %>
  </div>
</div>
