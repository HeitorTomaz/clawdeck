<%#
  Modal form used for both new and edit. Rendered inside a turbo_frame so the
  containing turbo_frame_tag in show.html.erb gets populated when the user
  clicks add/edit, then cleared on close.
%>
<div class="fixed inset-0 z-[60] flex items-center justify-center"
     data-controller="column-form-modal"
     data-action="keydown.esc->column-form-modal#close">
  <div class="absolute inset-0 bg-black/30" data-action="click->column-form-modal#close"></div>
  <div class="relative bg-bg-elevated border border-border rounded-2xl w-full max-w-md mx-4 overflow-hidden" style="box-shadow: 0 12px 40px rgba(0,0,0,0.12);">
    <div class="px-5 py-4 border-b border-border flex items-center justify-between">
      <span class="text-base font-semibold text-content"><%= title %></span>
      <button type="button"
              data-action="click->column-form-modal#close"
              class="p-2 rounded-md text-content-muted hover:text-content hover:bg-bg-hover transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%= form_with model: column, url: url, method: method, class: "p-5 space-y-4" do |form| %>
      <% if column.errors.any? %>
        <div class="p-3 bg-[#b3261e]/8 border border-[#b3261e]/25 text-[#b3261e] text-sm rounded-md">
          <ul class="list-disc list-inside">
            <% column.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-sm font-medium text-content mb-1.5">Column name</label>
        <%= form.text_field :name,
            required: true,
            autofocus: true,
            placeholder: "e.g., Backlog, Doing, Shipped",
            class: "w-full px-3 py-2 text-sm bg-bg-base border border-border rounded-md focus-soft text-content placeholder:text-content-muted" %>
      </div>

      <% available_agents = (defined?(current_user) && current_user.respond_to?(:agents)) ? current_user.agents.order(:name) : [] %>
      <div>
        <label class="block text-sm font-medium text-content mb-1.5">Assigned agent (optional)</label>
        <%= form.select :assigned_agent_id,
            available_agents.map { |a| [a.name, a.id] },
            { include_blank: "— No agent —", selected: column.assigned_agent_id },
            class: "w-full px-3 py-2 text-sm bg-bg-base border border-border rounded-md focus-soft text-content" %>
        <p class="mt-1 text-xs text-content-muted">
          Optional. Pin a default agent that owns work landing in this column.
        </p>
      </div>

      <% webhook_disabled_reason =
           if column.assigned_agent.nil?
             "Defina o agente atribuido (assigned agent) antes de habilitar o webhook."
           elsif column.assigned_agent.webhook_cron_id.blank?
             "O agente atribuido nao tem webhook_cron_id. Defina em Agents."
           end
      %>
      <div>
        <label class="flex items-start gap-2 text-sm text-content cursor-pointer <%= 'opacity-60 cursor-not-allowed' if webhook_disabled_reason %>"
               <%= "title=\"#{webhook_disabled_reason}\"".html_safe if webhook_disabled_reason %>>
          <%= form.check_box :webhook_enabled,
              { class: "mt-0.5", disabled: webhook_disabled_reason.present? } %>
          <span>
            Disparar webhook do agente quando uma task entrar nesta coluna
          </span>
        </label>
        <% if webhook_disabled_reason %>
          <p class="mt-1 text-xs text-content-muted"><%= webhook_disabled_reason %></p>
        <% else %>
          <p class="mt-1 text-xs text-content-muted">
            Invoca <code>cron.run</code> do OpenClaw configurado no agente.
          </p>
        <% end %>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <button type="button"
                data-action="click->column-form-modal#close"
                class="px-4 py-2 text-sm font-medium rounded-md border border-[rgba(28,28,28,0.4)] text-content hover:bg-bg-hover transition-colors cursor-pointer">
          Cancel
        </button>
        <%= form.submit submit_label,
            class: "px-4 py-2 text-sm font-medium rounded-md bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
