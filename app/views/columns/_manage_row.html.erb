<li id="manage-column-<%= column.id %>"
    class="flex items-center gap-2 px-3 py-2 rounded-lg bg-bg-elevated border border-white/[0.04] group"
    data-column-id="<%= column.id %>"
    data-controller="column-actions"
    data-column-actions-column-id-value="<%= column.id %>"
    data-column-actions-board-id-value="<%= @board.id %>">
  <%# Drag handle %>
  <span class="cursor-grab text-content-muted opacity-60 hover:opacity-100 transition-opacity drag-handle">
    <svg width="10" height="14" viewBox="0 0 10 14" fill="currentColor"><circle cx="2" cy="3" r="1"/><circle cx="8" cy="3" r="1"/><circle cx="2" cy="7" r="1"/><circle cx="8" cy="7" r="1"/><circle cx="2" cy="11" r="1"/><circle cx="8" cy="11" r="1"/></svg>
  </span>

  <span class="text-sm font-semibold text-content flex-1 truncate"><%= column.name %></span>

  <% if column.respond_to?(:assigned_agent) && column.assigned_agent.present? %>
    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-semibold"
          style="background:rgba(167,139,250,0.10);border:1px solid rgba(167,139,250,0.2);color:#a78bfa">
      <span class="inline-flex items-center justify-center w-4 h-4 rounded-full" style="background:rgba(167,139,250,0.25);font-size:9px;color:#e9d5ff">
        <%= column.assigned_agent.name.first.to_s.upcase %>
      </span>
      <%= column.assigned_agent.name %>
    </span>
  <% end %>

  <span class="text-[11px] font-medium text-content-muted">
    <%= column.tasks.count %> <%= column.tasks.count == 1 ? "task" : "tasks" %>
  </span>

  <%= link_to edit_board_column_path(@board, column),
      data: { turbo_frame: "column_form_modal" },
      class: "p-1.5 rounded text-content-muted hover:text-content hover:bg-white/[0.06] transition-colors",
      title: "Edit" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
    </svg>
  <% end %>

  <button type="button"
          data-action="click->column-actions#confirmDelete"
          data-column-name="<%= column.name %>"
          data-task-count="<%= column.tasks.count %>"
          class="p-1.5 rounded text-red-400 hover:bg-red-500/10 transition-colors cursor-pointer"
          title="Delete">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166M5.79 5.79c.34-.059.68-.114 1.022-.165m12.398.165a48.108 48.108 0 0 0-3.478-.397m-12 .562a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916" />
    </svg>
  </button>
</li>
