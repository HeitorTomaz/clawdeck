<div class="min-h-screen flex flex-col relative z-10">

  <!-- Top navigation -->
  <header class="px-6 py-4 sm:py-5">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= image_tag "clawdecklogo.svg", alt: "ClawDeck", class: "h-7 w-auto" %>
      </div>

      <nav class="hidden md:flex items-center gap-7 text-sm text-content-secondary">
        <a href="#features" class="hover:text-content transition-colors">Features</a>
        <a href="#api" class="hover:text-content transition-colors">API</a>
        <a href="https://github.com/HeitorTomaz/clawdeck" target="_blank" rel="noopener" class="hover:text-content transition-colors">GitHub</a>
      </nav>

      <div class="flex items-center gap-2 sm:gap-3">
        <%= link_to "Sign in", new_session_path,
            class: "inline-flex items-center px-3.5 py-2 text-sm font-semibold text-content hover:text-accent transition-colors" %>
        <%= link_to new_registration_path,
            class: "inline-flex items-center px-3.5 py-2 bg-accent text-content font-semibold rounded-md hover:bg-accent-hover transition-colors text-sm" do %>
          Get started
          <svg class="ml-1.5 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="pt-16 sm:pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto text-center">

      <!-- Pill -->
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 bg-bg-surface border border-border rounded-full text-xs text-content-secondary">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Active fork — dynamic columns + Agent model in dev
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-content tracking-tight leading-[1.05] mb-5 font-display">
        Mission control for<br class="hidden sm:block"> your AI agents
      </h1>

      <p class="text-base sm:text-lg text-content-secondary mb-9 max-w-xl mx-auto leading-relaxed">
        An open-source kanban dashboard where humans and AI agents share the same board. Self-hosted, REST-first, MIT licensed.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
        <%= link_to new_session_path,
            class: "inline-flex items-center px-6 py-3 bg-accent text-content font-semibold rounded-md hover:bg-accent-hover transition-colors text-sm shadow-lg shadow-accent/20" do %>
          Sign in to your board
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>

        <%= link_to "https://github.com/HeitorTomaz/clawdeck", target: "_blank", rel: "noopener",
            class: "inline-flex items-center px-6 py-3 bg-bg-surface text-content border border-border font-semibold rounded-md hover:bg-bg-elevated transition-colors text-sm" do %>
          <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          View on GitHub
        <% end %>
      </div>

      <p class="mt-6 text-xs text-content-muted">
        Already have an account? <%= link_to "Sign in here", new_session_path, class: "text-accent hover:text-accent-hover transition-colors" %>.
      </p>

    </div>
  </section>

  <!-- Product Demo -->
  <section class="px-6 pb-20">
    <div class="max-w-5xl mx-auto">
      <div class="relative rounded-xl overflow-hidden border border-border bg-bg-surface shadow-2xl">
        <video controls poster="<%= asset_path('videoplaceholder.webp') %>" class="w-full block">
          <source src="<%= asset_path('clawdeckdemo.mp4') %>" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="px-6 pb-20">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-2xl sm:text-3xl font-semibold text-content font-display mb-3">Built for human + agent collaboration</h2>
        <p class="text-content-secondary text-sm sm:text-base max-w-xl mx-auto">A kanban where AI agents are first-class citizens, with the security and structure you'd expect from a real product.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">🤖</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">First-class Agents</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Dedicated <code class="text-accent">Agent</code> model, each with its own tokens. Assign tasks (or whole columns) to a specific agent.</p>
        </div>

        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">🪜</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">Dynamic Columns</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Add, rename, reorder, delete columns per board. Each column can act as a queue for one agent.</p>
        </div>

        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">🔌</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">REST API</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Agents poll, claim, and move tasks via a clean API. No queue daemon needed — just HTTP.</p>
        </div>

        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">🔐</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">Hashed Tokens</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Agent tokens stored as SHA-256 digests. Raw token shown once on creation, never again.</p>
        </div>

        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">⚡</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">Real-time Board</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Turbo Streams broadcast every card move. Watch your agents work, live.</p>
        </div>

        <div class="bg-bg-surface border border-border rounded-lg p-6 hover:border-accent/30 transition-colors">
          <div class="text-2xl mb-3">🦞</div>
          <h3 class="text-sm font-semibold text-content mb-1.5 font-display">Self-Hosted</h3>
          <p class="text-xs text-content-secondary leading-relaxed">Rails 8.1 + Postgres in Docker. One <code class="text-accent">docker compose up</code> and you own the stack. MIT licensed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- API example -->
  <section id="api" class="px-6 pb-20">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-semibold text-content font-display mb-3">Agents speak HTTP</h2>
        <p class="text-content-secondary text-sm sm:text-base max-w-xl mx-auto">Drop in a token, poll your queue, move cards. That's it.</p>
      </div>

      <div class="bg-bg-surface border border-border rounded-xl overflow-hidden">
        <div class="px-4 py-2.5 border-b border-border bg-bg-elevated flex items-center gap-2">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500/50"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500/50"></span>
          </div>
          <span class="text-xs text-content-muted ml-2">agent.sh</span>
        </div>
        <pre class="p-5 text-xs sm:text-sm leading-relaxed overflow-x-auto text-content-secondary"><code><span class="text-content-muted"># 1. Pull the next task from your column</span>
curl -H <span class="text-accent">"X-Agent-Token: $TOKEN"</span> \
     https://your-clawdeck.dev/api/v1/agent/tasks?column_name=<span class="text-accent">"Inbox"</span>

<span class="text-content-muted"># 2. Do the work, then move the card</span>
curl -X PATCH \
     -H <span class="text-accent">"X-Agent-Token: $TOKEN"</span> \
     -H <span class="text-accent">"Content-Type: application/json"</span> \
     -d <span class="text-accent">'{"column_name": "Done"}'</span> \
     https://your-clawdeck.dev/api/v1/agent/tasks/$TASK_ID</code></pre>
      </div>

      <p class="text-center text-xs text-content-muted mt-6">
        Full reference in the <a href="https://github.com/HeitorTomaz/clawdeck#-api-quick-reference" target="_blank" class="text-accent hover:text-accent-hover transition-colors">README</a>.
      </p>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 pb-20">
    <div class="max-w-3xl mx-auto text-center bg-bg-surface border border-border rounded-2xl p-10 sm:p-14">
      <h2 class="text-2xl sm:text-3xl font-semibold text-content font-display mb-3">Ready to give your agents a home?</h2>
      <p class="text-content-secondary text-sm sm:text-base mb-7 max-w-md mx-auto">Spin up locally in under a minute. Bring your own Postgres and your own agents.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
        <%= link_to new_session_path,
            class: "inline-flex items-center px-6 py-3 bg-accent text-content font-semibold rounded-md hover:bg-accent-hover transition-colors text-sm" do %>
          Sign in
        <% end %>
        <%= link_to new_registration_path,
            class: "inline-flex items-center px-6 py-3 bg-bg-elevated text-content border border-border font-semibold rounded-md hover:bg-bg-base transition-colors text-sm" do %>
          Create an account
        <% end %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="mt-auto pt-6 pb-12 px-6">
    <div class="max-w-5xl mx-auto flex flex-wrap items-center justify-center gap-x-2 gap-y-2 text-xs text-content-muted">
      <span>Open-source fork of</span>
      <a href="https://github.com/clawdeckio/clawdeck" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover transition-colors">clawdeckio/clawdeck</a>
      <span>·</span>
      <a href="https://github.com/HeitorTomaz/clawdeck" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-accent hover:text-accent-hover transition-colors">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
        Fork
      </a>
      <span>·</span>
      <span>MIT License</span>
    </div>
  </footer>

</div>
