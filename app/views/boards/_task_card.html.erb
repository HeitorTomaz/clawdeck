<% has_current_user = defined?(current_user) && current_user %>
<% task_column = task.column %>
<% column_name = task_column&.name.to_s %>
<% is_done = column_name.downcase == "done" %>
<% board_color = task.board.color || "red" %>
<% assigned_agent = task.assigned_agent %>
<li id="task_<%= task.id %>"
    class="group cursor-grab transition-all duration-150 <%= 'opacity-50' if is_done %>"
    style="padding:14px 16px;background:#0d0d0d;border-radius:0;border:1px solid #262626;border-left:2px solid #262626"
    onmouseenter="this.style.borderLeftColor='#ffffff';this.style.borderColor='#3c3c3c';this.style.borderLeftColor='#ffffff'"
    onmouseleave="this.style.borderColor='#262626';this.style.borderLeftColor='#262626'"
    <% if has_current_user %>
      data-controller="dropdown delete-confirm"
      data-action="contextmenu->dropdown#openAtCursor"
      data-delete-confirm-item-name-value="<%= h(task.name.truncate(30)) %>"
    <% end %>
    data-task-id="<%= task.id %>"
    data-task-column-id="<%= task.column_id %>"
    data-task-position="<%= task.position %>">

  <%# Context Menu (right-click) - only rendered when current_user is available (not during broadcasts) %>
  <% if has_current_user %>
    <button data-dropdown-target="button" class="hidden" aria-expanded="false"></button>
    <div data-dropdown-target="menu" class="hidden fixed z-[100] min-w-[180px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
      <%# Agent Assignment submenu %>
      <% user_agents = current_user.respond_to?(:agents) ? current_user.agents.order(:name) : [] %>
      <% if user_agents.any? %>
        <div class="relative group/agent">
          <button type="button" class="w-full flex items-center justify-between gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors">
            <span class="flex items-center gap-2">
              <span class="w-4 text-center">🤖</span>
              <%= assigned_agent ? "Reassign agent" : "Assign to agent" %>
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>
          <div class="absolute left-full top-0 ml-1 hidden group-hover/agent:block min-w-[180px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
            <% user_agents.each do |agent| %>
              <%= button_to board_task_path(task.board, task),
                  method: :patch,
                  params: { task: { assigned_agent_id: agent.id } },
                  data: { action: "click->dropdown#close" },
                  class: "w-full flex items-center justify-between gap-3 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors" do %>
                <span class="flex items-center gap-2">
                  <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-purple-500/25 text-[9px] font-semibold text-purple-200"><%= agent.name.first.to_s.upcase %></span>
                  <%= agent.name %>
                </span>
                <% if assigned_agent&.id == agent.id %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-accent">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                <% end %>
              <% end %>
            <% end %>
            <% if assigned_agent %>
              <div class="border-t border-border my-1"></div>
              <%= button_to board_task_path(task.board, task),
                  method: :patch,
                  params: { task: { assigned_agent_id: "" } },
                  data: { action: "click->dropdown#close" },
                  class: "w-full text-left px-3 py-2 text-sm text-content-muted hover:bg-bg-hover transition-colors" do %>
                Unassign
              <% end %>
            <% end %>
          </div>
        </div>
        <div class="border-t border-border my-1"></div>
      <% end %>

      <%# Priority Selection - Submenu %>
      <div class="relative group/priority">
        <button type="button" class="w-full flex items-center justify-between gap-2 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
            </svg>
            Priority
          </span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </button>
        <%# Submenu %>
        <div class="absolute left-full top-0 ml-1 hidden group-hover/priority:block min-w-[140px] bg-bg-elevated border border-border rounded-lg shadow-lg py-1">
          <% [
            ["none", "None", nil, "text-content-muted"],
            ["low", "Low", 1, "text-yellow-500"],
            ["medium", "Medium", 2, "text-orange-500"],
            ["high", "High", 3, "text-accent"]
          ].each do |priority, label, flame_count, color| %>
            <%= button_to board_task_path(task.board, task),
                method: :patch,
                params: { task: { priority: priority } },
                data: { action: "click->dropdown#close" },
                class: "w-full flex items-center justify-between gap-3 px-3 py-2 text-sm text-content-secondary hover:bg-bg-hover transition-colors" do %>
              <span class="flex items-center gap-2">
                <% if flame_count.nil? %>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 <%= color %>">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                  </svg>
                <% else %>
                  <span class="flex -space-x-1.5">
                    <% flame_count.times do |i| %>
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 <%= color %>" style="position: relative; z-index: <%= flame_count - i %>;">
                        <path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" />
                      </svg>
                    <% end %>
                  </span>
                <% end %>
                <%= label %>
              </span>
              <% if task.priority == priority %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-accent">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="border-t border-border my-1"></div>

      <%# Delete Button - opens modal that's outside the dropdown %>
      <button type="button"
              data-action="click->delete-confirm#open click->dropdown#close"
              class="w-full flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-red-500/10 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
        </svg>
        Delete
      </button>
    </div>

    <%# Delete Confirmation Modal - outside the dropdown so it's not hidden when dropdown closes %>
    <%= render "application/delete_modal", url: board_task_path(task.board, task) %>
  <% end %>

  <%# Compute metadata flags %>
  <% subtask_total = task.respond_to?(:subtasks) ? task.subtasks.size : 0 %>
  <% subtask_done = subtask_total > 0 ? task.subtasks.count(&:done?) : 0 %>
  <%
    priority_dot_config = {
      "low" => { dots: 1, color: "#60a5fa" },
      "medium" => { dots: 2, color: "#fbbf24" },
      "high" => { dots: 3, color: "#ef4444" },
    }
    show_priority = task.priority.present? && task.priority != "none" && priority_dot_config[task.priority]
    p_cfg = priority_dot_config[task.priority]
    has_agent = assigned_agent.present?
    has_hint = task.respond_to?(:agent_hint) && task.agent_hint.present? && !is_done
    has_metadata = show_priority || subtask_total > 0 || has_agent || has_hint
  %>

  <%= link_to board_task_path(task.board, task), data: { turbo_frame: "task_panel" }, class: "block" do %>

  <%# Task Title %>
  <div style="font-size:13px;font-weight:500;color:<%= is_done ? '#555' : '#ffffff' %>;line-height:1.35;<%= 'margin-bottom:7px' if has_metadata %>">
    <%= task.name %>
  </div>

  <%# Priority dots + subtasks row %>
  <% if show_priority || subtask_total > 0 %>
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
      <% if show_priority %>
        <div style="display:flex;align-items:center;gap:2px">
          <% p_cfg[:dots].times do %>
            <div style="width:4px;height:4px;border-radius:50%;background:<%= p_cfg[:color] %>"></div>
          <% end %>
        </div>
      <% end %>
      <% if subtask_total > 0 %>
        <div style="display:flex;align-items:center;gap:4px">
          <span style="font-size:10px;font-weight:500;color:#444">☐ <%= subtask_done %>/<%= subtask_total %></span>
          <div style="width:32px;height:3px;border-radius:2px;background:rgba(255,255,255,0.06);overflow:hidden">
            <div style="height:100%;border-radius:2px;width:<%= subtask_total > 0 ? (subtask_done.to_f / subtask_total * 100).round : 0 %>%;opacity:0.7" class="bg-<%= board_color %>-500"></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Agent chip %>
  <% if has_agent %>
    <div style="display:inline-flex;align-items:center;gap:5px;margin-top:8px;padding:3px 8px;border-radius:6px;background:rgba(167,139,250,0.08);border:1px solid rgba(167,139,250,0.18);width:fit-content">
      <span style="display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:50%;background:rgba(167,139,250,0.25);font-size:9px;font-weight:700;color:#e9d5ff"><%= assigned_agent.name.first.to_s.upcase %></span>
      <span style="font-size:10px;font-weight:600;color:#c4b5fd"><%= assigned_agent.name %></span>
    </div>
  <% end %>

  <%# Agent hint %>
  <% if has_hint %>
    <div style="display:flex;align-items:center;gap:5px;margin-top:8px;padding:5px 8px;border-radius:6px;background:rgba(251,191,36,0.05);border:1px solid rgba(251,191,36,0.08)">
      <span style="font-size:9px">💡</span>
      <span style="font-size:10px;font-weight:500;color:#888;font-style:italic;line-height:1.3"><%= task.agent_hint %></span>
    </div>
  <% end %>

  <% end %>
</li>
