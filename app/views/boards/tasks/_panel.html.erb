<%# Task edit slide-in panel for kanban board %>
<%
  board_color_hex = board_hex_color(@board)

  # Warm palette per column position
  column_palette = ["#5f5f5d", "#1f5fa8", "#a07400", "#6d4eb8", "#1e7a4e", "#b3261e", "#2e8a8a", "#a07400"]
  current_column = task.column
  current_column_color = current_column ? column_palette[current_column.position.to_i % column_palette.length] : "#5f5f5d"

  available_columns = @board.columns.ordered
  available_agents  = (defined?(current_user) && current_user.respond_to?(:agents)) ? current_user.agents.order(:name) : []
  assigned_agent    = task.assigned_agent
%>

<div data-controller="task-modal"
     data-task-modal-task-id-value="<%= task.id %>"
     data-task-modal-update-url-value="<%= board_task_path(@board, task) %>">
  <!-- Backdrop -->
  <div data-task-modal-target="backdrop"
       data-action="click->task-modal#close"
       class="hidden opacity-0 transition-opacity duration-200 ease-out fixed inset-0 bg-black/20 z-[200]">
  </div>
  <!-- Slide-in Panel -->
  <div data-task-modal-target="modal"
       class="hidden translate-x-full transition-transform duration-200 ease-out fixed top-0 right-0 w-[420px] h-screen bg-bg-elevated border-l border-border flex flex-col z-[201] overflow-hidden">

    <!-- Header — column pill + close -->
    <div class="px-5 py-4 border-b border-border flex items-center justify-between">
      <div data-task-modal-target="statusPill" class="text-xs font-medium text-content bg-bg-base border border-border rounded-full px-3 py-1">
        <%= current_column&.name || "—" %>
      </div>
      <button type="button"
              data-action="click->task-modal#close"
              class="bg-transparent border-none cursor-pointer text-content-muted hover:text-content text-lg">✕</button>
    </div>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto px-5 pt-5 pb-8 flex flex-col gap-6">

      <%# === Auto-save form: title, notes, priority only === %>
      <%= form_with model: task, url: board_task_path(@board, task), method: :patch, class: "flex flex-col gap-6", data: { task_modal_target: "form" } do |form| %>
        <%= form.hidden_field :priority, value: task.priority, data: { task_modal_target: "priorityField" } %>

        <!-- Title -->
        <div>
          <%= form.text_field :name,
              placeholder: "Task title",
              class: "w-full text-2xl font-semibold text-content tracking-[-0.025em] leading-tight bg-transparent border-none outline-none p-0",
              data: { task_modal_target: "nameField", action: "input->task-modal#scheduleAutoSave" } %>
        </div>

        <!-- Notes -->
        <div>
          <%= form.text_area :description,
              placeholder: "Add notes...",
              class: "w-full min-h-[120px] p-3 rounded-md border border-border bg-bg-base text-sm text-content-secondary resize-y outline-none leading-relaxed focus-soft",
              data: { task_modal_target: "descriptionField", action: "input->task-modal#scheduleAutoSave" } %>
        </div>

        <!-- Hidden submit button (triggered programmatically) -->
        <%= form.submit "Save", class: "hidden", data: { task_modal_target: "submitButton" } %>
      <% end %>

      <%# === Details section === %>
      <div>
        <div class="text-sm font-semibold text-content mb-3.5">Details</div>

        <!-- Column row -->
        <div class="flex items-center justify-between mb-3" data-controller="dropdown">
          <span class="text-sm font-normal text-content-muted">Column</span>
          <div class="relative">
            <button type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" aria-expanded="false"
                    class="flex items-center gap-2 px-3 py-1.5 rounded-md cursor-pointer bg-bg-base border border-border hover:border-[rgba(28,28,28,0.4)] transition-colors">
              <div data-task-modal-target="statusDot" class="w-1.5 h-1.5 rounded-full" style="background:<%= current_column_color %>"></div>
              <span data-task-modal-target="statusLabel" class="text-sm font-medium text-content"><%= current_column&.name || "—" %></span>
              <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="opacity-50">
                <path d="M4 6L8 10L12 6" stroke="#5f5f5d" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute top-[calc(100%+4px)] right-0 w-[200px] p-1 rounded-lg bg-bg-elevated border border-border z-10" style="box-shadow:0 12px 40px rgba(0,0,0,0.12)">
              <% available_columns.each do |col| %>
                <% col_color = column_palette[col.position.to_i % column_palette.length] %>
                <button type="button"
                        data-action="click->task-modal#changeColumn"
                        data-column-id="<%= col.id %>"
                        data-column-label="<%= col.name %>"
                        data-column-dot="<%= col_color %>"
                        class="flex items-center gap-2.5 w-full px-2.5 py-2 rounded-md cursor-pointer border-none text-left transition-colors <%= task.column_id == col.id ? 'bg-bg-hover' : 'bg-transparent hover:bg-bg-hover' %>">
                  <div class="w-2 h-2 rounded-full" style="background:<%= col_color %>"></div>
                  <span class="text-sm font-medium flex-1 <%= task.column_id == col.id ? 'text-content' : 'text-content-secondary' %>"><%= col.name %></span>
                  <% if task.column_id == col.id %>
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="<%= col_color %>" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <% end %>
                </button>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Priority row -->
        <%
          priority_config = {
            "none"   => { dots: 0, color: "#5f5f5d", bg: "#fcfbf8",                border: "#eceae4" },
            "low"    => { dots: 1, color: "#1f5fa8", bg: "rgba(31,95,168,0.08)",   border: "rgba(31,95,168,0.25)" },
            "medium" => { dots: 2, color: "#a07400", bg: "rgba(160,116,0,0.08)",   border: "rgba(160,116,0,0.25)" },
            "high"   => { dots: 3, color: "#b3261e", bg: "rgba(179,38,30,0.08)",   border: "rgba(179,38,30,0.25)" },
          }
          current_p = priority_config[task.priority] || priority_config["none"]
        %>
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-normal text-content-muted">Priority</span>
          <button type="button"
                  data-action="click->task-modal#cyclePriority"
                  data-task-modal-target="priorityButton"
                  data-priority-value="<%= task.priority %>"
                  class="w-[100px] h-[30px] rounded-md cursor-pointer flex items-center justify-center gap-1 transition-colors"
                  style="background:<%= current_p[:bg] %>;border:1px solid <%= current_p[:border] %>">
            <% if current_p[:dots] == 0 %>
              <div class="w-1.5 h-1.5 rounded-full opacity-40" style="background:#5f5f5d"></div>
            <% else %>
              <% current_p[:dots].times do %>
                <div class="w-1.5 h-1.5 rounded-full" style="background:<%= current_p[:color] %>"></div>
              <% end %>
            <% end %>
          </button>
        </div>

        <!-- Agent row -->
        <div class="flex items-center justify-between" data-controller="dropdown">
          <span class="text-sm font-normal text-content-muted">Agent</span>
          <div class="relative">
            <button type="button" data-action="click->dropdown#toggle" data-dropdown-target="button" aria-expanded="false"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-md cursor-pointer transition-colors"
                    style="background:<%= assigned_agent ? 'rgba(109,78,184,0.08)' : '#fcfbf8' %>;border:1px solid <%= assigned_agent ? 'rgba(109,78,184,0.25)' : '#eceae4' %>">
              <% if assigned_agent %>
                <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-[#6d4eb8]/20 text-[9px] font-semibold text-[#6d4eb8]"><%= assigned_agent.name.first.to_s.upcase %></span>
                <span class="text-sm font-medium text-[#6d4eb8]"><%= assigned_agent.name %></span>
              <% else %>
                <span class="text-sm">🤖</span>
                <span class="text-sm font-medium text-content-muted">Assign</span>
              <% end %>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute top-[calc(100%+4px)] right-0 w-[200px] p-1 rounded-lg bg-bg-elevated border border-border z-10" style="box-shadow:0 12px 40px rgba(0,0,0,0.12)">
              <% if available_agents.empty? %>
                <div class="px-2.5 py-2 text-xs text-content-muted">No agents yet. <%= link_to "Create one", new_agent_path, class: "text-[#6d4eb8] underline" %>.</div>
              <% else %>
                <% available_agents.each do |agent| %>
                  <button type="button"
                          data-action="click->task-modal#changeAgent"
                          data-agent-id="<%= agent.id %>"
                          data-agent-name="<%= agent.name %>"
                          class="flex items-center gap-2.5 w-full px-2.5 py-2 rounded-md cursor-pointer border-none text-left <%= assigned_agent&.id == agent.id ? 'bg-bg-hover' : 'bg-transparent hover:bg-bg-hover' %>">
                    <span class="inline-flex items-center justify-center w-[18px] h-[18px] rounded-full bg-[#6d4eb8]/20 text-[10px] font-semibold text-[#6d4eb8]"><%= agent.name.first.to_s.upcase %></span>
                    <span class="text-sm font-medium flex-1 <%= assigned_agent&.id == agent.id ? 'text-content' : 'text-content-secondary' %>"><%= agent.name %></span>
                    <% if assigned_agent&.id == agent.id %>
                      <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="#6d4eb8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <% end %>
                  </button>
                <% end %>
                <% if assigned_agent %>
                  <div class="h-px bg-border my-1"></div>
                  <button type="button"
                          data-action="click->task-modal#changeAgent"
                          data-agent-id=""
                          data-agent-name=""
                          class="block w-full px-2.5 py-2 rounded-md bg-transparent border-none cursor-pointer text-left text-sm font-medium text-content-muted">
                    Unassign
                  </button>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Subtasks -->
      <% subtasks = task.subtasks %>
      <% if subtasks.any? %>
        <% done_count = subtasks.count(&:done?) %>
        <% total_count = subtasks.size %>
        <% progress = total_count > 0 ? (done_count.to_f / total_count * 100).round : 0 %>
        <div>
          <div class="flex items-center justify-between mb-2">
            <div class="text-sm font-semibold text-content">Subtasks</div>
            <span class="text-xs font-medium text-content-muted"><%= done_count %>/<%= total_count %></span>
          </div>
          <div class="h-1 rounded-full bg-bg-hover mb-2.5 overflow-hidden">
            <div class="h-full rounded-full" style="background:<%= board_color_hex %>;width:<%= progress %>%;opacity:0.85"></div>
          </div>
          <div id="task_<%= task.id %>_subtasks" class="flex flex-col gap-1">
            <% subtasks.each do |subtask| %>
              <%= button_to board_task_subtask_path(@board, task, subtask),
                  method: :patch,
                  params: { subtask: { done: !subtask.done? } },
                  class: "flex items-center gap-2.5 px-2.5 py-2 rounded-md bg-bg-base border border-border cursor-pointer hover:bg-bg-hover transition-colors" do %>
                <% if subtask.done? %>
                  <div class="w-4 h-4 rounded flex items-center justify-center flex-shrink-0" style="background:<%= board_color_hex %>">
                    <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M3 8.5L6.5 12L13 4" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                <% else %>
                  <div class="w-4 h-4 rounded border-[1.5px] border-[rgba(28,28,28,0.25)] bg-transparent flex-shrink-0"></div>
                <% end %>
                <span class="text-sm font-normal <%= subtask.done? ? 'text-content-muted line-through' : 'text-content-secondary' %>"><%= subtask.title %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Agent Suggestion Hint -->
      <% if task.respond_to?(:agent_hint) && task.agent_hint.present? %>
        <div class="px-3.5 py-3 rounded-md bg-[#a07400]/5 border border-[#a07400]/15 flex items-start gap-2.5">
          <span class="text-base mt-0.5">💡</span>
          <div>
            <div class="text-sm font-semibold text-[#a07400] mb-0.5">Suggestion</div>
            <div class="text-sm font-normal text-content-secondary leading-relaxed"><%= task.agent_hint %></div>
          </div>
        </div>
      <% end %>

      <!-- Activity Feed -->
      <div>
        <div class="text-sm font-semibold text-content mb-3.5">Activity</div>
        <%= render "shared/task_activities", task: task %>
      </div>
    </div>
  </div>
</div>
