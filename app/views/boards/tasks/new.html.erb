<%= turbo_frame_tag "new_task_modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center" data-controller="modal new-task-modal" data-action="keydown.esc->modal#close">
    <div class="absolute inset-0 bg-black/30" data-action="click->modal#close"></div>
    <div class="relative bg-bg-elevated border border-border rounded-2xl w-full max-w-md mx-4 overflow-hidden" style="box-shadow: 0 12px 40px rgba(0,0,0,0.12);">

      <!-- Header -->
      <div class="px-5 py-4 border-b border-border flex items-center justify-between">
        <span class="text-base font-semibold text-content">New Task</span>
        <%= link_to board_path(@board), class: "p-2 rounded-md text-content-muted hover:text-content hover:bg-bg-hover transition-colors", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        <% end %>
      </div>

      <%= form_with model: @task, url: board_tasks_path(@board), class: "px-5 py-6 space-y-6" do |form| %>
        <% if @task.errors.any? %>
          <div class="p-3 bg-[#b3261e]/8 border border-[#b3261e]/25 text-[#b3261e] text-xs rounded-md">
            <ul class="list-disc list-inside">
              <% @task.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form.hidden_field :priority, value: @task.priority || "none", data: { new_task_modal_target: "priorityField" } %>

        <!-- Title -->
        <div>
          <%= form.text_field :name,
              required: true,
              autofocus: true,
              placeholder: "Task title",
              class: "w-full text-xl font-semibold tracking-[-0.025em] bg-transparent border-none focus:outline-none focus:ring-0 text-content placeholder:text-content-muted p-0" %>
        </div>

        <!-- Notes -->
        <div>
          <%= form.text_area :description,
              placeholder: "Add notes...",
              rows: 3,
              class: "w-full text-sm leading-relaxed bg-bg-base border border-border focus-soft text-content-secondary placeholder:text-content-muted resize-none rounded-md px-3 py-3 outline-none" %>
        </div>

        <!-- Details -->
        <div class="border-t border-border pt-4">
          <h3 class="text-sm font-semibold text-content mb-4">Details</h3>

          <div class="space-y-4">
            <!-- Column -->
            <div class="flex items-center justify-between">
              <span class="text-sm text-content-muted">Column</span>
              <%= form.select :column_id,
                  @board.columns.ordered.map { |c| [c.name, c.id] },
                  { selected: (@task.column_id || @board.columns.ordered.first&.id) },
                  class: "px-3 py-1.5 text-sm rounded-md bg-bg-base border border-border text-content focus-soft" %>
            </div>

            <!-- Agent (optional) -->
            <% available_agents = current_user.respond_to?(:agents) ? current_user.agents.order(:name) : [] %>
            <% if available_agents.any? %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-content-muted">Agent</span>
                <%= form.select :assigned_agent_id,
                    available_agents.map { |a| [a.name, a.id] },
                    { include_blank: "— None —", selected: @task.assigned_agent_id },
                    class: "px-3 py-1.5 text-sm rounded-md bg-bg-base border border-border text-content focus-soft" %>
              </div>
            <% end %>

            <!-- Priority -->
            <div class="flex items-center justify-between">
              <span class="text-sm text-content-muted">Priority</span>
              <div class="flex gap-1.5" data-new-task-modal-target="priorityGroup">
                <button type="button" aria-pressed="<%= (@task.priority || 'none') == 'none' %>" data-action="click->new-task-modal#selectPriority" data-priority-value="none" data-new-task-modal-target="priorityButton" class="cursor-pointer inline-flex items-center justify-center px-2.5 py-1.5 rounded-md bg-bg-base border border-border hover:bg-bg-hover transition-colors duration-200 aria-pressed:bg-bg-hover aria-pressed:border-[rgba(28,28,28,0.4)]">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-content-dim">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
                  </svg>
                </button>
                <button type="button" aria-pressed="<%= @task.priority == 'low' %>" data-action="click->new-task-modal#selectPriority" data-priority-value="low" data-new-task-modal-target="priorityButton" class="cursor-pointer inline-flex items-center justify-center px-2.5 py-1.5 rounded-md bg-bg-base border border-border hover:bg-bg-hover transition-colors duration-200 aria-pressed:bg-bg-hover aria-pressed:border-[rgba(28,28,28,0.4)]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#1f5fa8]">
                    <path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" />
                  </svg>
                </button>
                <button type="button" aria-pressed="<%= @task.priority == 'medium' %>" data-action="click->new-task-modal#selectPriority" data-priority-value="medium" data-new-task-modal-target="priorityButton" class="cursor-pointer inline-flex items-center justify-center px-2.5 py-1.5 rounded-md bg-bg-base border border-border hover:bg-bg-hover transition-colors duration-200 aria-pressed:bg-bg-hover aria-pressed:border-[rgba(28,28,28,0.4)]">
                  <div class="flex -space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#a07400]" style="position: relative; z-index: 2;"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" /></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#a07400]" style="position: relative; z-index: 1;"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" /></svg>
                  </div>
                </button>
                <button type="button" aria-pressed="<%= @task.priority == 'high' %>" data-action="click->new-task-modal#selectPriority" data-priority-value="high" data-new-task-modal-target="priorityButton" class="cursor-pointer inline-flex items-center justify-center px-2.5 py-1.5 rounded-md bg-bg-base border border-border hover:bg-bg-hover transition-colors duration-200 aria-pressed:bg-bg-hover aria-pressed:border-[rgba(28,28,28,0.4)]">
                  <div class="flex -space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#b3261e]" style="position: relative; z-index: 3;"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" /></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#b3261e]" style="position: relative; z-index: 2;"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" /></svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#b3261e]" style="position: relative; z-index: 1;"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 0 0-1.071-.136 9.742 9.742 0 0 0-3.539 6.176 7.547 7.547 0 0 1-1.705-1.715.75.75 0 0 0-1.152-.082A9 9 0 1 0 15.68 4.534a7.46 7.46 0 0 1-2.717-2.248ZM15.75 14.25a3.75 3.75 0 1 1-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 0 1 1.925-3.546 3.75 3.75 0 0 1 3.255 3.718Z" clip-rule="evenodd" /></svg>
                  </div>
                </button>
              </div>
            </div>

          </div>
        </div>

        <!-- Footer -->
        <div class="flex items-center justify-end gap-3 pt-4 border-t border-border">
          <%= link_to "Cancel", board_path(@board), class: "px-4 py-2 text-sm font-medium rounded-md border border-[rgba(28,28,28,0.4)] text-content hover:bg-bg-hover transition-colors", data: { turbo_frame: "_top" } %>
          <%= form.submit "Create Task", class: "px-4 py-2 text-sm font-medium rounded-md bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
