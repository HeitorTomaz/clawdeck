<%# Remove the task card %>
<%= turbo_stream.remove "task_#{@task.id}" %>

<%# Update the column count %>
<% if @task.column_id %>
  <% column_count = @board.tasks.where(column_id: @task.column_id).count %>
  <%= turbo_stream.replace "column-#{@task.column_id}-count" do %>
    <span id="column-<%= @task.column_id %>-count" style="font-size:11px;font-weight:600;color:#444;background:rgba(255,255,255,0.04);padding:0 7px;border-radius:5px;line-height:20px"><%= column_count %></span>
  <% end %>
<% end %>

<%# Clear the panel - the modal will handle closing itself %>
<%= turbo_stream.update "task_panel", "" %>
