<% content_for :title, "#{@board.name} - clawdeck" %>
<% @board_page = true %>

<%# Subscribe to real-time updates for this board %>
<%= turbo_stream_from "board_#{@board.id}" %>

<div class="h-full flex flex-col" data-controller="board">
  <%# Unified Navbar %>
  <%= render "shared/navbar" %>

  <%# Board modals (new board, settings) %>
  <%= render "boards/header" %>

  <%# Columns management modal %>
  <%= render "columns/manage_modal" %>

  <%# Toast container (used for transient errors like delete column with tasks) %>
  <div id="toast-container" class="fixed top-4 right-4 z-[200] flex flex-col gap-2"></div>

  <%= render "shared/filter_bar", board: @board %>

  <%# Tag filter indicator %>
  <% if @current_tag.present? %>
    <div class="flex items-center gap-2 px-6 py-2 bg-bg-surface border-b border-border">
      <span class="text-xs text-content-muted">Filtered by:</span>
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-bg-elevated text-content">
        <%= @current_tag %>
        <%= link_to board_path(@board), class: "ml-1 hover:text-status-error" do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
            <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
          </svg>
        <% end %>
      </span>
    </div>
  <% end %>

  <%# Kanban Columns - scrollable page, variable height columns %>
  <div class="flex-1 overflow-auto bg-bg-base">
    <div id="board-columns"
         class="flex gap-2.5 items-start min-h-full"
         style="padding:12px 16px 16px"
         data-controller="columns"
         data-columns-reorder-url-value="<%= reorder_board_columns_path(@board) %>">
      <% @board.columns.ordered.each do |column| %>
        <%= render "boards/column", column: column, tasks: (@tasks_by_column || {})[column.id] || column.tasks.order(:position) %>
      <% end %>

      <%# Add column button %>
      <div class="flex-shrink-0" style="width:240px">
        <button type="button"
                data-action="click->columns#openManageModal"
                class="w-full flex items-center justify-center gap-1.5 cursor-pointer border border-dashed border-[#3c3c3c] bg-transparent hover:bg-white/[0.02] hover:border-white transition-colors"
                style="padding:10px 12px;font-size:11px;font-weight:700;color:#7e7e7e;text-transform:uppercase;letter-spacing:0.12em;border-radius:0">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M14 8H2M8 2V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Add column
        </button>
      </div>
    </div>
  </div>

  <%# Task Panel Container - loaded via Turbo Frame %>
  <%= turbo_frame_tag "task_panel" %>


  <%# New Task Modal %>
  <%= turbo_frame_tag "new_task_modal" %>

  <%# Column form modal (new/edit) - loaded via Turbo Frame %>
  <%= turbo_frame_tag "column_form_modal" %>

</div>
