<% content_for :title, "Home Dashboard - clawdeck" %>

<div class="max-w-[600px] mx-auto px-5 pb-12">

  <%# ─── Greeting + Progress ─── %>
  <div class="flex items-end justify-between pt-10 animate-fade-up">
    <div>
      <div class="text-sm font-medium text-content-muted mb-3">
        <%= Date.today.strftime("%A, %B %-d") %>
      </div>
      <h1 class="text-4xl font-semibold text-content tracking-[-0.03em] leading-tight">
        <span id="time-greeting"><%= time_greeting %>.</span>
      </h1>
      <script>
        (function() {
          var h = new Date().getHours();
          var g = h < 12 ? "Good morning" : h < 17 ? "Good afternoon" : "Good evening";
          document.getElementById("time-greeting").textContent = g;
        })();
      </script>
    </div>
    <div class="flex items-center gap-3.5">
      <div class="text-right">
        <div class="text-2xl font-semibold text-content tracking-[-0.025em]">
          <%= @completed_today_count %>/<%= @all_today_tasks.size %>
        </div>
        <div class="text-xs text-content-muted">done today</div>
      </div>
      <% progress = @all_today_tasks.size > 0 ? (@completed_today_count.to_f / @all_today_tasks.size) : 0 %>
      <div class="relative w-11 h-11">
        <svg width="44" height="44" viewBox="0 0 44 44" style="transform: rotate(-90deg)">
          <circle cx="22" cy="22" r="18" fill="none" stroke="#eceae4" stroke-width="4" />
          <circle cx="22" cy="22" r="18" fill="none" stroke="#1c1c1c" stroke-width="4"
            stroke-dasharray="<%= (progress * 113).round(1) %> 113" stroke-linecap="round"
            style="transition: stroke-dasharray 0.6s ease" />
        </svg>
      </div>
    </div>
  </div>

  <%# ─── Agent Status Bar ─── %>
  <% if @agent_tasks_count > 0 %>
    <div class="flex items-center gap-1.5 pt-4 pb-6 animate-fade-up" style="animation-delay: 0.04s">
      <div class="w-1.5 h-1.5 rounded-full bg-[#a07400] animate-pulse-dot"></div>
      <span class="text-sm font-medium text-[#a07400]">
        Agent working on <%= pluralize(@agent_tasks_count, "task") %>
      </span>
    </div>
  <% else %>
    <div class="pt-4 pb-6"></div>
  <% end %>

  <%# ─── Today's Tasks ─── %>
  <div class="mb-10">
    <div class="flex items-center justify-between mb-3 animate-fade-up" style="animation-delay: 0.06s">
      <h2 class="text-sm font-semibold text-content">Today</h2>
      <div class="flex-1 ml-4 h-px bg-border"></div>
    </div>

    <div class="flex flex-col gap-2">
      <% if @all_today_tasks.empty? %>
        <div class="px-4 py-8 rounded-xl text-center animate-fade-up bg-bg-elevated border border-border" style="animation-delay: 0.08s;">
          <div class="text-sm font-medium text-content-muted">No tasks for today</div>
          <div class="text-xs text-content-muted mt-1 opacity-70">Tasks in "Up Next" and "In Progress" will appear here</div>
        </div>
      <% else %>
        <% @all_today_tasks.each_with_index do |task, i| %>
          <% color = board_hex_color(task.board) %>
          <% is_done = task.completed? %>
          <a href="<%= board_path(task.board) %>"
             class="flex items-start relative overflow-hidden animate-fade-up cursor-pointer bg-bg-elevated border border-border rounded-xl px-4 py-3.5 hover:bg-bg-hover transition-colors <%= 'opacity-50' if is_done %>"
             style="animation-delay: <%= (0.08 + i * 0.04).round(2) %>s;">

            <%# Task content %>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium leading-snug mb-1.5 <%= is_done ? 'text-content-muted line-through' : 'text-content' %>">
                <%= task.name %>
              </div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <%# Board/project pill %>
                <span class="text-xs font-medium rounded-full px-2 py-0.5 border"
                      style="color: <%= color %>; background: <%= hex_to_rgba(color, 0.06) %>; border-color: <%= hex_to_rgba(color, 0.2) %>;">
                  <%= task.board.icon %> <%= task.board.name %>
                </span>
                <%# Due date label %>
                <% if task.due_date.present? %>
                  <span class="text-xs font-normal text-content-muted bg-bg-base border border-border px-2 py-0.5 rounded-full">
                    <%= task.due_date == Date.today ? "Today" : task.due_date.strftime("%-m/%-d") %>
                  </span>
                <% end %>
              </div>
            </div>

            <%# Agent indicator %>
            <% task_agent = task.respond_to?(:assigned_agent) ? task.assigned_agent : nil %>
            <% if task_agent.present? %>
              <div class="flex items-center gap-1 self-start px-2 py-1 rounded-full bg-[#6d4eb8]/8 border border-[#6d4eb8]/20">
                <span class="inline-flex items-center justify-center w-3.5 h-3.5 rounded-full bg-[#6d4eb8]/20 text-[9px] font-semibold text-[#6d4eb8]"><%= task_agent.name.first.to_s.upcase %></span>
                <span class="text-xs font-medium text-[#6d4eb8]">
                  <%= task_agent.name %>
                </span>
              </div>
            <% end %>
          </a>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ─── Agent Activity ─── %>
  <div class="mb-10">
    <div class="flex items-center gap-2 mb-3 animate-fade-up" style="animation-delay: 0.28s">
      <span class="text-sm">🤖</span>
      <h2 class="text-sm font-semibold text-content">Agent Activity</h2>
      <div class="flex-1 ml-3 h-px bg-border"></div>
    </div>
    <div class="flex flex-col gap-2">
      <% if @agent_updates.empty? %>
        <div class="animate-fade-up rounded-xl px-4 py-3 bg-[#a07400]/4 border border-[#a07400]/15" style="animation-delay: 0.32s;">
          <div class="text-sm font-medium text-content-muted">No recent agent activity</div>
          <div class="text-xs text-content-muted opacity-70 mt-1">Assign tasks to your agent to see updates here</div>
        </div>
      <% else %>
        <% @agent_updates.each_with_index do |activity, i| %>
          <div class="animate-fade-up rounded-xl px-4 py-3 bg-[#a07400]/4 border border-[#a07400]/15"
               style="animation-delay: <%= (0.32 + i * 0.04).round(2) %>s;">
            <div class="text-sm font-normal text-content-secondary leading-snug">
              <%= activity.task.name %> &mdash; <%= activity.description %>
            </div>
            <div class="text-xs text-content-muted mt-1">
              <%= time_ago_in_words(activity.created_at) %> ago
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# ─── This Week — Activity Chart ─── %>
  <% max_val = [@week_stats.map { |d| d[:you] + d[:agent] }.max || 1, 1].max %>
  <% today_idx = (Date.today.cwday - 1) % 7 %>
  <% total_you = @week_stats.sum { |d| d[:you] } %>
  <% total_agent = @week_stats.sum { |d| d[:agent] } %>

  <div class="mb-10 animate-fade-up rounded-xl bg-bg-elevated border border-border px-5 py-5" style="animation-delay: 0.48s;">
    <div class="flex items-center justify-between mb-5">
      <div class="text-sm font-semibold text-content">This week</div>
      <div class="flex gap-3.5">
        <div class="flex items-center gap-1.5">
          <div class="w-2 h-2 rounded-sm bg-[#b3261e]"></div>
          <span class="text-xs font-normal text-content-muted">You (<%= total_you %>)</span>
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-2 h-2 rounded-sm bg-[#a07400]"></div>
          <span class="text-xs font-normal text-content-muted">Agent (<%= total_agent %>)</span>
        </div>
      </div>
    </div>

    <%# Stacked bar chart %>
    <div class="flex items-end gap-1.5 h-[90px] mb-2">
      <% @week_stats.each_with_index do |d, i| %>
        <% total = d[:you] + d[:agent] %>
        <% you_h = max_val > 0 ? (d[:you].to_f / max_val * 72).round(1) : 0 %>
        <% agent_h = max_val > 0 ? (d[:agent].to_f / max_val * 72).round(1) : 0 %>
        <% is_today = i == today_idx %>

        <div class="flex-1 flex flex-col items-center h-full justify-end">
          <% if total > 0 %>
            <div class="text-xs font-semibold mb-1 <%= is_today ? 'text-content' : 'text-content-muted' %>"><%= total %></div>
          <% end %>
          <div class="flex flex-col gap-px w-full max-w-[42px]">
            <% if agent_h > 0 %>
              <div class="<%= 'rounded-t' if you_h > 0 %> <%= 'rounded' if you_h == 0 %>" style="height: <%= agent_h %>px; background: <%= is_today ? '#a07400' : 'rgba(160,116,0,0.25)' %>;"></div>
            <% end %>
            <% if you_h > 0 %>
              <div class="<%= 'rounded-b' if agent_h > 0 %> <%= 'rounded' if agent_h == 0 %>" style="height: <%= you_h %>px; background: <%= is_today ? '#b3261e' : 'rgba(179,38,30,0.25)' %>;"></div>
            <% end %>
            <% if total == 0 %>
              <div class="h-[3px] rounded bg-border w-full"></div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# Day labels %>
    <div class="flex gap-1.5">
      <% @week_stats.each_with_index do |d, i| %>
        <div class="flex-1 text-center text-xs <%= i == today_idx ? 'font-semibold text-content' : 'font-normal text-content-muted' %>">
          <%= d[:day] %>
        </div>
      <% end %>
    </div>

    <%# Summary row %>
    <div class="flex justify-around mt-5 pt-4 border-t border-border">
      <div class="text-center">
        <div class="text-xl font-semibold text-content tracking-[-0.02em]"><%= @completed_count %></div>
        <div class="text-xs font-normal text-content-muted mt-0.5">completed</div>
      </div>
      <div class="text-center">
        <div class="text-xl font-semibold text-[#a07400] tracking-[-0.02em]"><%= @in_progress_count %></div>
        <div class="text-xs font-normal text-content-muted mt-0.5">in progress</div>
      </div>
      <div class="text-center">
        <div class="text-xl font-semibold text-content-muted tracking-[-0.02em]"><%= @upcoming_count %></div>
        <div class="text-xs font-normal text-content-muted mt-0.5">upcoming</div>
      </div>
    </div>
  </div>

  <%# ─── Boards (Projects) ─── %>
  <div class="mb-12">
    <div class="flex items-center gap-3 mb-3 animate-fade-up" style="animation-delay: 0.52s;">
      <h2 class="text-sm font-semibold text-content">Boards</h2>
      <span class="flex-1 h-px bg-border"></span>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <% @boards.each_with_index do |board, i| %>
        <% task_count = board.tasks.where(completed: false).count %>
        <%= link_to board_path(board),
            class: "flex items-center gap-3 animate-fade-up rounded-xl bg-bg-elevated border border-border px-4 py-3.5 hover:bg-bg-hover transition-colors",
            style: "animation-delay: #{(0.56 + i * 0.04).round(2)}s;" do %>
          <span class="text-xl"><%= board.icon %></span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-content truncate"><%= board.name %></div>
            <div class="text-xs font-normal text-content-muted mt-0.5"><%= pluralize(task_count, "task") %></div>
          </div>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="opacity-30">
            <path d="M6 4L10 8L6 12" stroke="#1c1c1c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>

</div>
