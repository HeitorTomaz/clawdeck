<% content_for :title, "Forgot password" %>
<div class="max-w-md mx-auto pt-12">
  <div class="text-left mb-8">
    <h1 class="text-4xl font-semibold tracking-[-0.03em] text-content mb-3">Forgot your password?</h1>
    <p class="text-base text-content-secondary">Enter your email and we'll send you reset instructions.</p>
  </div>

  <%= form_with url: passwords_path, class: "space-y-4 mb-6", html: { autocomplete: "off" } do |form| %>
    <div>
      <%= form.label :email_address, "Email", class: "block text-sm font-medium text-content mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", placeholder: "name@domain.com", value: params[:email_address], class: "block w-full px-4 h-11 bg-bg-base border border-border rounded-md focus-soft text-content text-sm placeholder:text-content-muted" %>
    </div>
    <div class="pt-2 flex items-center justify-between">
      <%= form.submit "Email reset instructions", class: "cursor-pointer h-11 px-6 bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity text-sm font-medium rounded-md" %>
      <%= link_to "Back to sign in", new_session_path, class: "text-sm text-content-muted hover:text-content underline transition-colors" %>
    </div>
  <% end %>
</div>
