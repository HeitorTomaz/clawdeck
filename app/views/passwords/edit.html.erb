<% content_for :title, "Reset password" %>
<div class="max-w-md mx-auto pt-12">
  <div class="text-left mb-8">
    <h1 class="text-4xl font-semibold tracking-[-0.03em] text-content mb-3">Update your password</h1>
    <p class="text-base text-content-secondary">Enter your new password below.</p>
  </div>

  <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4 mb-6", html: { autocomplete: "off" } do |form| %>
    <div>
      <%= form.label :password, "New password", class: "block text-sm font-medium text-content mb-2" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Enter new password", maxlength: 72, class: "block w-full px-4 h-11 bg-bg-base border border-border rounded-md focus-soft text-content text-sm placeholder:text-content-muted" %>
    </div>
    <div>
      <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-content mb-2" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm new password", maxlength: 72, class: "block w-full px-4 h-11 bg-bg-base border border-border rounded-md focus-soft text-content text-sm placeholder:text-content-muted" %>
    </div>
    <div class="pt-2">
      <%= form.submit "Update password", class: "cursor-pointer h-11 px-6 bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-opacity text-sm font-medium rounded-md" %>
    </div>
  <% end %>
</div>
