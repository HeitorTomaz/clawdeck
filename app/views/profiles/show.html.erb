<% content_for :title, "Settings" %>
<% content_for :breadcrumb_standalone, "Settings" %>

<div class="space-y-6 mt-12">
  <!-- Section 1: Profile -->
  <div class="bg-bg-elevated border border-border rounded-xl p-6 space-y-4">
    <h3 class="text-base font-semibold text-content tracking-[-0.01em]">Profile</h3>

    <%= form_with(model: @user, url: settings_path, method: :patch, class: "space-y-4") do |form| %>
      <!-- Avatar -->
      <div>
        <label class="block text-xs font-medium text-content-secondary mb-2">Avatar</label>
        <div class="flex items-center gap-4">
          <% if @user.has_avatar? %>
            <%= image_tag @user.avatar_source, class: "w-14 h-14 object-cover rounded-full" %>
          <% else %>
            <div class="w-14 h-14 rounded-full bg-bg-elevated flex items-center justify-center">
              <svg class="w-7 h-7 text-content-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
          <% end %>
          <div class="flex-1">
            <%= form.file_field :avatar, accept: "image/jpeg,image/jpg,image/png,image/webp", class: "block w-full text-xs text-content-secondary file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-bg-elevated file:text-content-secondary hover:file:bg-bg-hover file:cursor-pointer file:transition-colors" %>
            <p class="text-xs text-content-muted mt-1">Max 512KB, 256x256px. JPEG, PNG, or WebP.</p>
          </div>
        </div>
        <% if @user.avatar.attached? || @user.avatar_url.present? %>
          <div class="mt-3">
            <label class="flex items-center text-xs text-content-secondary cursor-pointer">
              <%= form.check_box :remove_avatar, class: "mr-2 rounded border-border bg-bg-elevated text-accent focus:ring-accent focus:ring-offset-bg-surface" %>
              Remove avatar
            </label>
          </div>
        <% end %>
        <% if @user.errors[:avatar].any? %>
          <div class="mt-2">
            <% @user.errors[:avatar].each do |error| %>
              <p class="text-[#b3261e] text-xs">Avatar <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Email -->
      <div class="pt-4 border-t border-border">
        <label class="block text-xs font-medium text-content-secondary mb-1.5">Email Address</label>
        <%= form.email_field :email_address, placeholder: "your@email.com", class: "block w-full bg-bg-elevated border-0 rounded-md px-3 py-2 text-sm text-content placeholder:text-content-muted focus:ring-1 focus:ring-accent focus:outline-none" %>
        <% if @user.errors[:email_address].any? %>
          <div class="mt-1">
            <% @user.errors[:email_address].each do |error| %>
              <p class="text-[#b3261e] text-xs">Email <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="pt-2">
        <%= form.submit "Save profile", class: "cursor-pointer px-4 py-2 bg-content text-content-inverse btn-inset-shadow hover:opacity-90 text-xs font-semibold rounded-md transition-colors duration-200" %>
      </div>
    <% end %>
  </div>

  <!-- Section 2: Agents -->
  <div class="bg-bg-elevated border border-border rounded-xl p-6 space-y-4">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="text-base font-semibold text-content tracking-[-0.01em]">Agents & API tokens</h3>
        <p class="text-xs text-content-muted mt-1">Each connected automation is an agent. Tokens are bound to a specific agent.</p>
      </div>
      <%= link_to "Manage all", agents_path,
          class: "px-3 py-1.5 text-xs font-semibold rounded-md border border-border hover:bg-bg-hover text-content-secondary transition-colors" %>
    </div>

    <% user_agents = @user.respond_to?(:agents) ? @user.agents.order(:name) : [] %>

    <% if user_agents.empty? %>
      <div class="bg-bg-elevated rounded-md px-3 py-4 text-center">
        <p class="text-xs text-content-secondary mb-3">No agents yet. Create one to connect an automation.</p>
        <%= link_to "Create agent", new_agent_path,
            class: "inline-flex px-3 py-1.5 text-xs font-semibold rounded-md bg-content text-content-inverse btn-inset-shadow hover:opacity-90 transition-colors" %>
      </div>
    <% else %>
      <ul class="space-y-3 list-none p-0 m-0">
        <% user_agents.each do |agent| %>
          <li class="bg-bg-elevated rounded-md p-3">
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-2.5 min-w-0">
                <div class="w-8 h-8 rounded-md bg-[#6d4eb8]/15 border border-[#6d4eb8]/25 flex items-center justify-center text-xs font-bold text-[#6d4eb8]">
                  <%= agent.name.first.to_s.upcase %>
                </div>
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-content truncate"><%= agent.name %></div>
                  <div class="text-[10px] text-content-muted">
                    <%= agent.api_tokens.count %> token(s)
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to "Edit", edit_agent_path(agent),
                    class: "px-2 py-1 text-[10px] font-semibold rounded border border-border hover:bg-bg-hover text-content-secondary transition-colors" %>
                <%= button_to "New token", regenerate_token_agent_path(agent),
                    method: :post,
                    data: { turbo_confirm: "Generate a new token? You'll only see it once." },
                    class: "px-3 py-1.5 text-xs font-medium rounded-md border border-border text-content-secondary hover:bg-bg-hover hover:text-content transition-colors cursor-pointer" %>
              </div>
            </div>

            <%# Show raw_token once, right after creation %>
            <% if defined?(@new_raw_token) && @new_raw_token.present? && defined?(@new_raw_token_agent_id) && @new_raw_token_agent_id == agent.id %>
              <div class="mt-3 p-2.5 rounded-md bg-[#1e7a4e]/8 border border-[#1e7a4e]/30" data-controller="clipboard">
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#1e7a4e] mb-1.5">New token — copy now, you won't see it again</div>
                <div class="flex items-center gap-2">
                  <code data-clipboard-target="source"
                        class="flex-1 text-[11px] font-mono text-content-secondary bg-bg-base px-2 py-1.5 rounded break-all"><%= @new_raw_token %></code>
                  <button type="button"
                          data-action="click->clipboard#copy"
                          class="px-2 py-1.5 text-[10px] font-semibold rounded bg-bg-base hover:bg-bg-hover text-content-secondary transition-colors cursor-pointer">
                    <span data-clipboard-target="label">Copy</span>
                  </button>
                </div>
              </div>
            <% end %>

            <% tokens = agent.api_tokens.order(created_at: :desc) %>
            <% if tokens.any? %>
              <ul class="mt-3 space-y-1 list-none p-0 m-0">
                <% tokens.each do |token| %>
                  <li class="flex items-center justify-between gap-3 px-2 py-1.5 bg-bg-base rounded">
                    <span class="text-[10px] font-mono text-content-muted">****<%= token.id.to_s.last(6) %></span>
                    <span class="text-[10px] text-content-muted">created <%= time_ago_in_words(token.created_at) %> ago</span>
                    <%= button_to "Revoke", agent_token_path(agent, token),
                        method: :delete,
                        data: { turbo_confirm: "Revoke this token?" },
                        class: "px-1.5 py-0.5 text-[10px] font-semibold rounded text-[#b3261e] hover:bg-[rgba(179,38,30,0.06)] transition-colors cursor-pointer" %>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>

    <!-- Connected Agent (legacy heartbeat indicator, kept for backwards compat with agent_last_active_at) -->
    <% if @user.respond_to?(:agent_last_active_at) && @user.agent_last_active_at.present? %>
      <div class="pt-4 border-t border-border">
        <p class="text-xs font-medium text-content-secondary mb-3">Last activity</p>
        <div class="flex items-center gap-3">
          <span class="text-xl"><%= @user.agent_emoji || "🤖" %></span>
          <span class="text-sm text-content"><%= @user.agent_name || "Agent" %></span>
          <span class="text-xs text-content-muted">•</span>
          <span class="text-xs text-content-muted">Last active: <%= time_ago_in_words(@user.agent_last_active_at) %> ago</span>
        </div>
      </div>
    <% end %>
  </div>
</div>
